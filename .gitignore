cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Credentials
.env
config.json
secrets.yaml

# Large files
*.xlsx
*.xls
*.zip

# Temp
scratch/
_old/
temp_*.ipynb
EOF